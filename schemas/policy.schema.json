{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeos.dev/schemas/policy.schema.json",
  "title": "AEOS Core Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "description", "precedence", "policies"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "precedence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "level", "scope", "statement", "rationale", "evidence", "source"],
        "properties": {
          "id": { "type": "string", "pattern": "^AEOS-[A-Z]+-[0-9]{3}$" },
          "title": { "type": "string", "minLength": 1 },
          "level": { "enum": ["required", "recommended"] },
          "scope": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

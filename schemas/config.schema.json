{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeos.dev/schemas/config.schema.json",
  "title": "AEOS Adapter Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "policySource", "knowledge", "maxEntryLines", "pipelines"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 2 },
    "policySource": { "type": "string", "minLength": 1 },
    "knowledge": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "maxEntryLines": { "type": "integer", "minimum": 20 },
    "pipelines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["platform", "renderer", "target", "installTarget"],
        "properties": {
          "platform": { "type": "string", "minLength": 1 },
          "aliases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "renderer": { "enum": ["agents", "cursor", "markdown", "system"] },
          "target": { "type": "string", "pattern": "^dist/" },
          "installTarget": { "type": "string", "minLength": 1 },
          "mirrors": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
